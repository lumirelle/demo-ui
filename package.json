{
  "name": "demo-ui",
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "description": "_description_",
  "author": "Lumirelle <shabbyacc@outlook.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/lumirelle",
  "homepage": "https://github.com/lumirelle/demo-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumirelle/demo-ui.git"
  },
  "bugs": "https://github.com/lumirelle/demo-ui/issues",
  "keywords": [],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./button": {
      "import": {
        "types": "./dist/button.d.ts",
        "default": "./dist/button.js"
      },
      "require": {
        "types": "./dist/button.d.ts",
        "default": "./dist/button.cjs"
      }
    },
    "./button.css": "./dist/button.css",
    "./input": {
      "import": {
        "types": "./dist/input.d.ts",
        "default": "./dist/input.js"
      },
      "require": {
        "types": "./dist/input.d.ts",
        "default": "./dist/input.cjs"
      }
    },
    "./input.css": "./dist/input.css",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "workspaces": {
    "packages": [".", "playground/vite", "playground/nuxt"],
    "catalogs": {
      "dev": {
        "bumpp": "^11.0.1",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657",
        "vue": "^3.5.34"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.3",
        "@types/node": "^25.6.0",
        "bun-types": "^1.3.13",
        "typescript": "^6.0.3"
      },
      "build": {
        "@vitejs/plugin-vue": "^6.0.6",
        "vite": "^8.0.11",
        "vite-plugin-dts": "^5.0.0"
      },
      "playground": {
        "nuxt": "^4.4.4"
      },
      "check": {
        "@antfu/eslint-config": "^8.2.0",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.3.0",
        "eslint": "^10.3.0",
        "eslint-plugin-oxlint": "^1.63.0",
        "knip": "^6.11.0",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.63.0",
        "oxlint-tsgolint": "^0.22.1",
        "publint": "^0.3.19"
      },
      "test": {
        "tsnapi": "^0.3.2"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "vite",
    "build": "vite build",
    "start": "vite preview",
    "play:vite": "bun run --cwd playground/vite dev",
    "play:nuxt": "bun run --cwd playground/nuxt dev",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "bun test",
    "prerelease": "bun run build && bun run --parallel check test",
    "release": "bumpp"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "@vitejs/plugin-vue": "catalog:build",
    "bumpp": "catalog:dev",
    "bun-types": "catalog:types",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:dev",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types",
    "vite": "catalog:build",
    "vite-plugin-dts": "catalog:build",
    "vue": "catalog:dev"
  },
  "overrides": {
    "typescript": "$typescript"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
