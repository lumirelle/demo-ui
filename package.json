{
  "type": "module",
  "version": "0.0.0",
  "packageManager": "bun@1.3.13",
  "workspaces": {
    "packages": [
      "packages/*",
      "playground/*"
    ],
    "catalogs": {
      "dev": {
        "@vue/language-core": "^3.2.8",
        "vue": "^3.5.34"
      },
      "types": {
        "@lumirelle/tsconfig": "^0.1.4",
        "@types/node": "^25.6.2",
        "bun-types": "^1.3.13",
        "typescript": "^6.0.3"
      },
      "build": {
        "@vitejs/plugin-vue": "^6.0.6",
        "vite": "^8.0.11",
        "vite-plugin-dts": "^5.0.0"
      },
      "prod": {
        "@nuxt/kit": "^4.4.4",
        "unplugin-vue-components": "^32.0.0"
      },
      "playground": {
        "nuxt": "^4.4.4"
      },
      "check": {
        "@antfu/eslint-config": "^8.2.0",
        "@arethetypeswrong/cli": "^0.18.2",
        "@lumirelle/oxlint-config": "^0.3.0",
        "eslint": "^10.3.0",
        "eslint-plugin-oxlint": "^1.63.0",
        "knip": "^6.12.2",
        "nano-staged": "^1.0.2",
        "oxlint": "^1.63.0",
        "oxlint-tsgolint": "^0.22.1",
        "publint": "^0.3.20",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git#7625657"
      },
      "test": {
        "tsnapi": "^0.3.2"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bun run --cwd packages/ui dev",
    "build": "bun run --cwd packages/ui build",
    "start": "bun run --cwd packages/ui start",
    "play:vite": "bun run --cwd playground/vite dev",
    "play:nuxt": "bun run --cwd playground/nuxt dev",
    "play:build:vite": "bun run --cwd playground/vite build",
    "play:build:nuxt": "bun run --cwd playground/nuxt build",
    "play:start:vite": "bun run --cwd playground/vite start",
    "play:start:nuxt": "bun run --cwd playground/nuxt start",
    "lint": "bun run --parallel oxlint eslint",
    "lint:fix": "oxlint --fix && eslint --fix",
    "typecheck": "tsc --build --noEmit",
    "unused": "knip-bun",
    "pubcheck": "bun run --parallel 'attw --pack --profile esm-only' publint",
    "check": "bun run --parallel lint typecheck unused pubcheck",
    "test": "bun test"
  },
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:check",
    "@arethetypeswrong/cli": "catalog:check",
    "@lumirelle/oxlint-config": "catalog:check",
    "@lumirelle/tsconfig": "catalog:types",
    "@types/node": "catalog:types",
    "bun-types": "catalog:types",
    "demo-ui": "workspace:*",
    "eslint": "catalog:check",
    "eslint-plugin-oxlint": "catalog:check",
    "knip": "catalog:check",
    "nano-staged": "catalog:check",
    "oxlint": "catalog:check",
    "oxlint-tsgolint": "catalog:check",
    "publint": "catalog:check",
    "simple-git-hooks": "catalog:check",
    "tsnapi": "catalog:test",
    "typescript": "catalog:types"
  },
  "overrides": {
    "typescript": "catalog:types",
    "vite": "catalog:build"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx nano-staged"
  },
  "nano-staged": {
    "*": [
      "oxlint --no-error-on-unmatched-pattern",
      "eslint"
    ]
  }
}
